{
  "name": "@openinc/node-red-contrib-openinc-parse",
  "version": "0.1.0",
  "description": "Node-RED nodes to interact with a configurable Parse Server (CRUD, queries and LiveQuery subscriptions)",
  "scripts": {
    "copy": "copyfiles -u 2 \"./src/nodes/**/*.{png,svg}\" \"./dist/nodes/\"",
    "build:editor": "rollup -c rollup.config.editor.mjs",
    "build:editor:watch": "rollup -c rollup.config.editor.mjs -w",
    "build:runtime": "tsc -p tsconfig.runtime.json",
    "build:runtime:watch": "tsc -p tsconfig.runtime.watch.json --watch --preserveWatchOutput",
    "build": "rimraf dist && npm run copy && npm run build:editor && npm run build:runtime",
    "dev": "rimraf dist && npm run copy && concurrently --kill-others --names 'COPY,EDITOR,RUNTIME' --prefix '({name})' --prefix-colors 'yellow.bold,cyan.bold,greenBright.bold' 'onchange -v \"src/**/*.png\" \"src/**/*.svg\" -- npm run copy' 'npm run build:editor:watch' 'npm run build:runtime:watch'",
    "lint": "prettier --ignore-path .eslintignore --check '**/*.{js,ts,md}'",
    "lint:fix": "prettier --ignore-path .eslintignore --write '**/*.{js,ts,md}'",
    "publishToNPM": "npm publish --access public"
  },
  "author": "Martin Stein",
  "keywords": [
    "node-red",
    "node",
    "parse-server",
    "parse",
    "livequery",
    "open.INC"
  ],
  "contributors": [
    "open.INC GmbH"
  ],
  "license": "MIT",
  "node-red": {
    "version": ">=2.0.0",
    "nodes": {
      "openinc-parse-config": "./dist/nodes/openinc-parse-config/openinc-parse-config.js",
      "openinc-parse-save": "./dist/nodes/openinc-parse-save/openinc-parse-save.js",
      "openinc-parse-delete": "./dist/nodes/openinc-parse-delete/openinc-parse-delete.js",
      "openinc-parse-find": "./dist/nodes/openinc-parse-find/openinc-parse-find.js",
      "openinc-parse-fetch-relation": "./dist/nodes/openinc-parse-fetch-relation/openinc-parse-fetch-relation.js",
      "openinc-parse-querybuilder": "./dist/nodes/openinc-parse-querybuilder/openinc-parse-querybuilder.js",
      "openinc-parse-subscribe": "./dist/nodes/openinc-parse-subscribe/openinc-parse-subscribe.js",
      "openinc-parse-changestream": "./dist/nodes/openinc-parse-changestream/openinc-parse-changestream.js"
    }
  },
  "dependencies": {
    "tslib": "^2.8.1",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/node": "^22.15.21",
    "@types/node-red": "^1.3.5",
    "@types/ws": "^8.18.1",
    "concurrently": "^5.3.0",
    "copyfiles": "^2.4.1",
    "glob": "^11.0.2",
    "onchange": "^7.1.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "rollup": "^4.41.0",
    "typescript": "^5.8.3"
  }
}
